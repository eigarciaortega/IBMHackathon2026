### Crear espacio (solo admin)
POST http://localhost:3001/spaces
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6MSwiZW1haWwiOiJhZG1pbkBjb3Jwb3JhdGl2b2FscGhhLmNvbSIsInBlcmZpbCI6IkFETUlOSVNUUkFET1IiLCJpYXQiOjE3ODIxNjYxNDAsImV4cCI6MTc4MjI1MjU0MH0.COwbnn7WVS9kvqBAOGuqDeVFALW91n_yQJgc2Kj00yU
Content-Type: application/json

{
  "nombre": "Sala de Prueba",
  "tipo": "SALA",
  "capacidad": 6,
  "piso": "Piso 1",
  "con_proyector": true,
  "con_aire": false,
  "con_pizarron": false,
  "con_tv": false
}

### Actualizar espacio
PUT http://localhost:3001/spaces/1
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6MSwiZW1haWwiOiJhZG1pbkBjb3Jwb3JhdGl2b2FscGhhLmNvbSIsInBlcmZpbCI6IkFETUlOSVNUUkFET1IiLCJpYXQiOjE3ODIxNjYxNDAsImV4cCI6MTc4MjI1MjU0MH0.COwbnn7WVS9kvqBAOGuqDeVFALW91n_yQJgc2Kj00yU
Content-Type: application/json

{
  "nombre": "Sala Creativa Actualizada",
  "capacidad": 10
}

### Eliminar espacio (soft delete)
DELETE http://localhost:3001/spaces/1
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6MSwiZW1haWwiOiJhZG1pbkBjb3Jwb3JhdGl2b2FscGhhLmNvbSIsInBlcmZpbCI6IkFETUlOSVNUUkFET1IiLCJpYXQiOjE3ODIxNjYxNDAsImV4cCI6MTc4MjI1MjU0MH0.COwbnn7WVS9kvqBAOGuqDeVFALW91n_yQJgc2Kj00yU
