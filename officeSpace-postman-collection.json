{
  "info": {
    "name": "OfficeSpace API",
    "description": "Colección completa de la API de OfficeSpace — auth, catalog y booking services. Ejecutar en orden: primero Login para obtener el token JWT.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "officeSpace-hackathon-2026"
  },
  "variable": [
    { "key": "AUTH_URL",    "value": "http://localhost:8083" },
    { "key": "CATALOG_URL", "value": "http://localhost:8081" },
    { "key": "BOOKING_URL", "value": "http://localhost:8082" },
    { "key": "TOKEN",       "value": "" },
    { "key": "SPACE_ID",    "value": "" },
    { "key": "BOOKING_ID",  "value": "" }
  ],
  "item": [
    {
      "name": "1. Auth Service",
      "item": [
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('TOKEN', json.token);",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Token received', () => pm.expect(json.token).to.be.a('string'));",
                  "pm.test('Role is ADMIN', () => pm.expect(json.role).to.eql('ADMIN'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@corporativoalpha.com\",\n  \"password\": \"Admin123\"\n}"
            },
            "url": { "raw": "{{AUTH_URL}}/api/auth/login", "host": ["{{AUTH_URL}}"], "path": ["api","auth","login"] }
          }
        },
        {
          "name": "Login (Collaborator)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Role is COLLABORATOR', () => pm.expect(json.role).to.eql('COLLABORATOR'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"carlos.mendez@corporativoalpha.com\",\n  \"password\": \"User123\"\n}"
            },
            "url": { "raw": "{{AUTH_URL}}/api/auth/login", "host": ["{{AUTH_URL}}"], "path": ["api","auth","login"] }
          }
        },
        {
          "name": "Login (credenciales inválidas)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"noexiste@test.com\",\n  \"password\": \"wrong\"\n}"
            },
            "url": { "raw": "{{AUTH_URL}}/api/auth/login", "host": ["{{AUTH_URL}}"], "path": ["api","auth","login"] }
          }
        }
      ]
    },
    {
      "name": "2. Catalog Service — Espacios",
      "item": [
        {
          "name": "Listar todos los espacios",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Es un array', () => pm.expect(json).to.be.an('array'));",
                  "if (json.length > 0) {",
                  "  pm.collectionVariables.set('SPACE_ID', json[0].publicId);",
                  "  pm.test('Espacio tiene publicId', () => pm.expect(json[0].publicId).to.be.a('string'));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{CATALOG_URL}}/api/resources", "host": ["{{CATALOG_URL}}"], "path": ["api","resources"] }
          }
        },
        {
          "name": "Filtrar por tipo ROOM",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Todos son ROOM', () => json.forEach(s => pm.expect(s.type).to.eql('ROOM')));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{CATALOG_URL}}/api/resources?type=ROOM",
              "host": ["{{CATALOG_URL}}"], "path": ["api","resources"],
              "query": [{ "key": "type", "value": "ROOM" }]
            }
          }
        },
        {
          "name": "Filtrar por tipo DESK",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Todos son DESK', () => json.forEach(s => pm.expect(s.type).to.eql('DESK')));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{CATALOG_URL}}/api/resources?type=DESK",
              "host": ["{{CATALOG_URL}}"], "path": ["api","resources"],
              "query": [{ "key": "type", "value": "DESK" }]
            }
          }
        },
        {
          "name": "Filtrar por capacidad mínima",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Todos tienen capacidad >= 8', () => json.forEach(s => pm.expect(s.capacity).to.be.at.least(8)));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{CATALOG_URL}}/api/resources?minCapacity=8",
              "host": ["{{CATALOG_URL}}"], "path": ["api","resources"],
              "query": [{ "key": "minCapacity", "value": "8" }]
            }
          }
        },
        {
          "name": "Detalle de un espacio",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Tiene publicId', () => pm.expect(json.publicId).to.be.a('string'));",
                  "pm.test('Tiene name', () => pm.expect(json.name).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{CATALOG_URL}}/api/resources/{{SPACE_ID}}", "host": ["{{CATALOG_URL}}"], "path": ["api","resources","{{SPACE_ID}}"] }
          }
        },
        {
          "name": "Crear espacio (ADMIN)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('SPACE_ID', json.publicId);",
                  "pm.test('Espacio creado con publicId', () => pm.expect(json.publicId).to.be.a('string'));",
                  "pm.test('Nombre correcto', () => pm.expect(json.name).to.eql('Sala Test Postman'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sala Test Postman\",\n  \"type\": \"ROOM\",\n  \"capacity\": 8,\n  \"location\": \"Piso 99\",\n  \"features\": {\n    \"has_projector\": true,\n    \"whiteboard\": false,\n    \"monitors\": 1\n  }\n}"
            },
            "url": { "raw": "{{CATALOG_URL}}/api/resources", "host": ["{{CATALOG_URL}}"], "path": ["api","resources"] }
          }
        },
        {
          "name": "Actualizar espacio (ADMIN)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "var json = pm.response.json();",
                  "pm.test('Capacidad actualizada', () => pm.expect(json.capacity).to.eql(12));"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sala Test Postman (actualizada)\",\n  \"type\": \"ROOM\",\n  \"capacity\": 12,\n  \"location\": \"Piso 99\",\n  \"features\": {}\n}"
            },
            "url": { "raw": "{{CATALOG_URL}}/api/resources/{{SPACE_ID}}", "host": ["{{CATALOG_URL}}"], "path": ["api","resources","{{SPACE_ID}}"] }
          }
        },
        {
          "name": "Eliminar espacio (ADMIN — soft delete)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 204', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }],
            "url": { "raw": "{{CATALOG_URL}}/api/resources/{{SPACE_ID}}", "host": ["{{CATALOG_URL}}"], "path": ["api","resources","{{SPACE_ID}}"] }
          }
        },
        {
          "name": "Crear espacio sin auth (debe fallar 401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401 o 403', () => pm.expect(pm.response.code).to.be.oneOf([401, 403]));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"No debería crearse\",\n  \"type\": \"ROOM\",\n  \"capacity\": 4,\n  \"location\": \"X\"\n}"
            },
            "url": { "raw": "{{CATALOG_URL}}/api/resources", "host": ["{{CATALOG_URL}}"], "path": ["api","resources"] }
          }
        }
      ]
    },
    {
