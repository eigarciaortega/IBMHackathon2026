# NeoWallet — Variables de entorno

# Secreto compartido entre servicios (debe coincidir en ambos)
INTERNAL_API_KEY=cambiar-por-secreto-seguro-en-produccion

# accounts-service → accounts_db
ACCOUNTS_DB_HOST=localhost
ACCOUNTS_DB_PORT=5432
ACCOUNTS_DB_USER=neowallet
ACCOUNTS_DB_PASSWORD=neowallet_dev
ACCOUNTS_DB_NAME=accounts_db
ACCOUNTS_DB_SSLMODE=disable

# processor-service → processor_db
PROCESSOR_DB_HOST=localhost
PROCESSOR_DB_PORT=5433
PROCESSOR_DB_USER=neowallet
PROCESSOR_DB_PASSWORD=neowallet_dev
PROCESSOR_DB_NAME=processor_db
PROCESSOR_DB_SSLMODE=disable

# processor-service → accounts-service (URL interna)
ACCOUNTS_SERVICE_URL=http://accounts-service:3000

# Puertos
ACCOUNTS_SERVICE_PORT=3000
PROCESSOR_SERVICE_PORT=3001