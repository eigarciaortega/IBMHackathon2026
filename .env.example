# ==========================================================
# OfficeSpace - Variables de entorno (plantilla)
# Copia este archivo a `.env` y ajusta los valores.
# ==========================================================

# --- Autenticación / JWT ---
# Clave simétrica compartida (HS256) para firmar y verificar el Token_JWT.
# Usa un valor largo y aleatorio en cualquier entorno real.
JWT_SECRET=cambia-esta-clave-por-un-secreto-largo-y-aleatorio
# Validez del token en segundos (R1.1 => 3600).
JWT_EXPIRES_IN=3600

# --- Zona horaria de la oficina ---
# Las horas de las reservas se manejan como hora-pared de esta zona.
# El booking-service calcula el "ahora" en esta zona (IANA tz database).
OFFICE_TZ=America/Mexico_City

# --- Base de datos MySQL compartida ---
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=officespace
MYSQL_USER=officespace
MYSQL_PASSWORD=officespace

# --- Conexión usada por los servicios backend ---
# Dentro de docker-compose el host es el nombre del servicio `db`.
DB_HOST=db
DB_PORT=3306
DB_NAME=officespace
DB_USER=officespace
DB_PASSWORD=officespace

# --- Puertos de los servicios ---
AUTH_SERVICE_PORT=3001
CATALOG_SERVICE_PORT=3002
BOOKING_SERVICE_PORT=3003
FRONTEND_PORT=5173
