# =====================================================================
# NeoWallet — Variables OPCIONALES para envíos REALES
# =====================================================================
# El sistema funciona sin tocar nada de esto:
#   · Correos -> cuenta de prueba Ethereal con URL de vista previa real
#   · SMS     -> simulados y consultables vía API (buzón por teléfono)
#
# Copia este archivo a `.env` SOLO si quieres envíos reales:
#   cp .env.example .env
# =====================================================================

# --- Correo real por SMTP (Gmail, SendGrid, Mailtrap, etc.) ----------
# Si dejas SMTP_HOST vacío, se usa Ethereal automáticamente.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=NeoWallet <no-reply@neowallet.com>

# --- SMS real por Twilio --------------------------------------------
# Si dejas estas vacías, los SMS se simulan (se guardan y se pueden leer
# por API), pero NO se envían a teléfonos reales.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
