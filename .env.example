# =====================================================================
# OfficeSpace — Variables de entorno (plantilla)
# Copiar a .env y completar. El archivo .env NUNCA debe subirse al repo.
# =====================================================================

# ---- Entorno ----
NODE_ENV=development
TZ=America/Mexico_City

# ---- Base de datos (PostgreSQL compartida) ----
POSTGRES_USER=officespace
POSTGRES_PASSWORD=change_me
POSTGRES_DB=officespace
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://officespace:change_me@localhost:5432/officespace?schema=public

# ---- Autenticación (JWT) — el MISMO secreto en los 3 microservicios ----
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=2h

# ---- Rate limiting (login, decisión S-02) ----
THROTTLE_TTL=900
THROTTLE_LIMIT=5

# ---- Puertos de los microservicios (local sin Docker) ----
AUTH_SERVICE_PORT=3001
CATALOG_SERVICE_PORT=3002
BOOKING_SERVICE_PORT=3003

# ---- CORS (orígenes permitidos por los microservicios) ----
CORS_ORIGIN=http://localhost:5173

# ---- Frontend (Vite) — URLs base de cada microservicio ----
VITE_AUTH_URL=http://localhost:3001/api/v1
VITE_CATALOG_URL=http://localhost:3002/api/v1
VITE_BOOKING_URL=http://localhost:3003/api/v1
FRONTEND_URL=http://localhost:5173

# ---- OfficeSpace Assistant · IBM Watson Assistant (OPCIONAL) ----
# Si se dejan vacías, el asistente usa el motor local rule-based (sin red, sin IA).
# Si se completan las TRES primeras, catalog-service intentará usar IBM Watson
# Assistant v2 (REST, sin SDK) y caerá al motor local si la llamada falla.
# NO subir credenciales reales al repositorio.
IBM_WATSON_ASSISTANT_API_KEY=
IBM_WATSON_ASSISTANT_URL=
IBM_WATSON_ASSISTANT_ID=
IBM_WATSON_ASSISTANT_VERSION=2023-06-15
