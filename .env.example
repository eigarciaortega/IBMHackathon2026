# Secreto JWT compartido por los tres microservicios.
# Cámbialo en producción por una cadena larga y aleatoria.
JWT_SECRET=ibm-officespace-shared-secret-change-me

# =====================================================================
# Google Calendar (calendario embebido + auto-sincronización de reservas)
# docker-compose toma estas variables de este archivo (.env).
# Guía paso a paso: GOOGLE_CALENDAR_SETUP.md
# Déjalas vacías para desplegar sin Google (el calendario sale "no configurado").
# =====================================================================
GOOGLE_CALENDAR_ID=
# Clave de la cuenta de servicio como JSON en una sola línea o en base64.
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_CALENDAR_EMBED_URL=
GOOGLE_CALENDAR_TIMEZONE=America/Mexico_City
GOOGLE_EVENT_COLOR_ADMIN=11
GOOGLE_EVENT_COLOR_COLLABORATOR=9
