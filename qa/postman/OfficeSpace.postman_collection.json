    {
      "name": "Booking — reserva solapada (409) [bug: solapamiento + status code]",
      "event": [
        { "listen": "test", "script": { "exec": [
          "pm.test('NO es 200/201 (no debe aceptar el solape)', () => pm.expect(pm.response.code).to.not.be.oneOf([200,201]));",
          "pm.test('es 409 Conflict', () => pm.response.to.have.status(409));",
          "pm.test('código RESERVA_SOLAPADA', () => pm.expect(pm.response.json().error.codigo).to.eql('RESERVA_SOLAPADA'));"
        ], "type": "text/javascript" } }
