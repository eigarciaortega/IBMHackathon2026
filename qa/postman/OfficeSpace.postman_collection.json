      "request": { "method": "GET", "url": "{{catalog_url}}/spaces" }
    },
    {
      "name": "Catalog — listar con token (200)",
      "event": [
        { "listen": "test", "script": { "exec": [
          "pm.test('200', () => pm.response.to.have.status(200));",
          "pm.test('devuelve un arreglo', () => pm.expect(pm.response.json()).to.be.an('array'));"
        ], "type": "text/javascript" } }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{carlos_token}}" }],
        "url": "{{catalog_url}}/spaces"
      }
    },
    {
      "name": "Catalog — filtro tipo=DESK y capacidad_min=1 (200)",
      "event": [
        { "listen": "test", "script": { "exec": [
          "pm.test('200', () => pm.response.to.have.status(200));",
          "const j = pm.response.json();",
          "pm.test('todos son DESK', () => j.forEach(e => pm.expect(e.tipo).to.eql('DESK')));",
          "pm.test('capacidad >= 1', () => j.forEach(e => pm.expect(e.capacidad).to.be.at.least(1)));"
        ], "type": "text/javascript" } }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{carlos_token}}" }],
