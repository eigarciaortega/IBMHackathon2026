        ], "type": "text/javascript" } }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{auth_url}}/auth/login",
        "body": { "mode": "raw", "raw": "{\"email\":\"admin@corporativoalpha.com\",\"password\":\"incorrecta\"}" }
      }
    },
    {
      "name": "Catalog — listar sin token (401) [bug: endpoint sin auth]",
      "event": [
        { "listen": "test", "script": { "exec": [
          "pm.test('401 sin token', () => pm.response.to.have.status(401));"
        ], "type": "text/javascript" } }
