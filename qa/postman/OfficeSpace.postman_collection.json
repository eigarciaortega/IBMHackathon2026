{
  "info": {
    "name": "OfficeSpace — Contrato y casos de QA",
    "description": "Colección Newman que valida el contrato de la API y cubre las clases de bugs del brief: solapamiento no detectado, capacidad sin validar, status code incorrecto en conflicto (409 vs 200), endpoints sin autenticación y borrado de reservas ajenas. La colección es autocontenida y re-ejecutable: crea su propio espacio y limpia lo que genera.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Fechas relativas para que los casos no queden en el pasado.",
          "function ymd(d){const p=n=>String(n).padStart(2,'0');return `${d.getFullYear()}-${p(d.getMonth()+1)}-${p(d.getDate())}`;}",
          "const manana=new Date();manana.setDate(manana.getDate()+1);",
          "const ayer=new Date();ayer.setDate(ayer.getDate()-1);",
          "pm.collectionVariables.set('manana', ymd(manana));",
          "pm.collectionVariables.set('ayer', ymd(ayer));"
        ]
      }
    }
  ],
  "variable": [
    { "key": "auth_url", "value": "http://localhost:8081" },
    { "key": "catalog_url", "value": "http://localhost:8082" },
    { "key": "booking_url", "value": "http://localhost:8083" }
  ],
  "item": [
    {
      "name": "Auth — login admin (200)",
      "event": [
        { "listen": "test", "script": { "exec": [
          "pm.test('200', () => pm.response.to.have.status(200));",
          "const j = pm.response.json();",
          "pm.test('devuelve token y rol ADMIN', () => { pm.expect(j.token).to.be.a('string'); pm.expect(j.rol).to.eql('ADMINISTRADOR'); });",
          "pm.collectionVariables.set('admin_token', j.token);"
        ], "type": "text/javascript" } }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{auth_url}}/auth/login",
        "body": { "mode": "raw", "raw": "{\"email\":\"admin@corporativoalpha.com\",\"password\":\"Admin123\"}" }
      }
    },
    {
      "name": "Auth — login colaborador Carlos (200)",
      "event": [
        { "listen": "test", "script": { "exec": [
          "pm.test('200', () => pm.response.to.have.status(200));",
          "const j = pm.response.json();",
          "pm.test('rol COLABORADOR', () => pm.expect(j.rol).to.eql('COLABORADOR'));",
          "pm.collectionVariables.set('carlos_token', j.token);"
        ], "type": "text/javascript" } }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{auth_url}}/auth/login",
        "body": { "mode": "raw", "raw": "{\"email\":\"carlos.mendez@corporativoalpha.com\",\"password\":\"User123\"}" }
      }
    },
    {
      "name": "Auth — login colaborador Ana (200)",
      "event": [
        { "listen": "test", "script": { "exec": [
          "pm.test('200', () => pm.response.to.have.status(200));",
          "pm.collectionVariables.set('ana_token', pm.response.json().token);"
        ], "type": "text/javascript" } }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{auth_url}}/auth/login",
        "body": { "mode": "raw", "raw": "{\"email\":\"ana.torres@corporativoalpha.com\",\"password\":\"User123\"}" }
      }
    },
