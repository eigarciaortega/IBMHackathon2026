{
  "info": {
    "name": "NeoWallet P2P Payments",
    "_postman_id": "neowallet-p2p-2026",
    "description": "Suite de pruebas para NeoWallet P2P Payments. Importa este archivo en Postman y ejecuta primero la carpeta 'Autenticación' para obtener los tokens.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "ACCOUNTS_URL", "value": "http://localhost:3000", "type": "string" },
    { "key": "PROCESSOR_URL", "value": "http://localhost:3001", "type": "string" },
    { "key": "INTERNAL_KEY", "value": "internal-neowallet-key-2026", "type": "string" },
    { "key": "TOKEN_A", "value": "", "type": "string" },
    { "key": "TOKEN_B", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "1. Autenticación",
      "item": [
        {
          "name": "1.1 ✅ Obtener token - Usuario A (exitoso)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.accessToken) {",
                  "  pm.collectionVariables.set('TOKEN_A', json.accessToken);",
                  "  console.log('TOKEN_A guardado');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"usuario.a@neowallet.com\",\"password\":\"password123\"}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{ACCOUNTS_URL}}/auth/token", "host": ["{{ACCOUNTS_URL}}"], "path": ["auth", "token"] }
          }
        },
        {
          "name": "1.2 ✅ Obtener token - Usuario B",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.accessToken) {",
                  "  pm.collectionVariables.set('TOKEN_B', json.accessToken);",
                  "  console.log('TOKEN_B guardado');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"usuario.b@neowallet.com\",\"password\":\"password123\"}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{ACCOUNTS_URL}}/auth/token", "host": ["{{ACCOUNTS_URL}}"], "path": ["auth", "token"] }
          }
        },
        {
          "name": "1.3 ❌ Credenciales inválidas (401)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"usuario.a@neowallet.com\",\"password\":\"wrong-password\"}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{ACCOUNTS_URL}}/auth/token", "host": ["{{ACCOUNTS_URL}}"], "path": ["auth", "token"] }
          }
        },
        {
          "name": "1.4 ❌ Email con formato inválido (400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"no-es-un-email\",\"password\":\"password123\"}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{ACCOUNTS_URL}}/auth/token", "host": ["{{ACCOUNTS_URL}}"], "path": ["auth", "token"] }
          }
        }
      ]
    },
    {
      "name": "2. RF-001: Consultar Saldo",
      "item": [
        {
          "name": "2.1 ✅ Saldo Usuario A ($1000)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN_A}}" }],
            "url": { "raw": "{{ACCOUNTS_URL}}/accounts/1", "host": ["{{ACCOUNTS_URL}}"], "path": ["accounts", "1"] }
          }
        },
        {
          "name": "2.2 ✅ Saldo Usuario B ($50)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN_A}}" }],
