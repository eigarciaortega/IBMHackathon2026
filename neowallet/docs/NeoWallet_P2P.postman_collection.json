            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN_A}}" }],
            "url": { "raw": "{{ACCOUNTS_URL}}/accounts/3", "host": ["{{ACCOUNTS_URL}}"], "path": ["accounts", "3"] }
          }
        },
        {
          "name": "2.4 ❌ Usuario no existe (404)",
