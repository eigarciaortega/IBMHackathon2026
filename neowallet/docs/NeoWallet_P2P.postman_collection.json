          }
        },
        {
          "name": "2.6 ❌ Token inválido (401)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer token-invalido-xxx" }],
            "url": { "raw": "{{ACCOUNTS_URL}}/accounts/1", "host": ["{{ACCOUNTS_URL}}"], "path": ["accounts", "1"] }
          }
        }
      ]
    },
