spring.application.name=catalogService
server.port=8081

spring.datasource.url=${DB_URL:jdbc:postgresql://localhost:5432/officeSpace}
spring.datasource.username=${DB_USERNAME:postgres}
spring.datasource.password=${DB_PASSWORD:your_db_password_here}

spring.jpa.hibernate.ddl-auto=update

jwt.secret=${JWT_SECRET:your_jwt_secret_min_256_bits_here}
jwt.expiration=${JWT_EXPIRATION:86400000}

springdoc.api-docs.path=/v3/api-docs
springdoc.swagger-ui.path=/swagger-ui.html
springdoc.swagger-ui.operationsSorter=method
