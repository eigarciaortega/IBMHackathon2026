{
    "swagger": "2.0",
    "info": {
        "description": "Servicio de cuentas de NeoWallet: consulta de saldo, recarga y actualización de balance con idempotencia.",
        "title": "NeoWallet - Accounts Service",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:3000",
    "basePath": "/",
    "paths": {
        "/accounts/update-balance": {
            "post": {
                "description": "Débito o crédito atómico con idempotencia. Requiere X-Internal-Key.",
                "tags": [
                    "internal"
                ],
                "summary": "Actualizar balance (interno)",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Clave secreta interna",
                        "name": "X-Internal-Key",
                        "in": "header",
                        "required": true
                    },
                    {
                        "description": "Datos de la operación",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/models.UpdateBalanceRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/models.UpdateBalanceResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/apperror.AppError"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/apperror.AppError"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/apperror.AppError"
                        }
                    }
                }
            }
        },
        "/accounts/{user_id}": {
            "get": {
                "description": "Obtiene los datos de un usuario incluyendo su saldo actual",
                "tags": [
                    "accounts"
                ],
                "summary": "Consultar saldo",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "ID del usuario",
                        "name": "user_id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/models.User"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/apperror.AppError"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/apperror.AppError"
                        }
                    }
                }
            }
        },
        "/api/recharge": {
            "post": {
                "description": "Incrementa el saldo de un usuario de forma atómica (simula recarga externa)",
                "tags": [
                    "accounts"
                ],
                "summary": "Recargar saldo",
                "parameters": [
                    {
                        "description": "Datos de recarga",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/models.RechargeRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/models.RechargeResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/apperror.AppError"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/apperror.AppError"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "apperror.AppError": {
            "type": "object",
            "properties": {
                "error": {
                    "type": "string"
                },
                "mensaje": {
                    "type": "string"
                },
                "transaction_id": {
                    "type": "string"
                }
            }
        },
        "models.RechargeRequest": {
            "type": "object",
            "properties": {
                "amount": {
                    "type": "number"
                },
                "payment_method": {
                    "type": "string"
                },
                "user_id": {
                    "type": "integer"
                }
            }
        },
        "models.RechargeResponse": {
            "type": "object",
            "properties": {
                "new_balance": {
                    "type": "number"
                }
            }
        },
        "models.UpdateBalanceRequest": {
            "type": "object",
            "properties": {
                "amount": {
                    "type": "number"
                },
                "idempotency_key": {
                    "type": "string"
                },
                "operation": {
                    "type": "string"
                },
                "user_id": {
                    "type": "integer"
                }
            }
        },
        "models.UpdateBalanceResponse": {
            "type": "object",
            "properties": {
                "new_balance": {
                    "type": "number"
                },
                "previous_balance": {
                    "type": "number"
                }
            }
        },
        "models.User": {
            "type": "object",
            "properties": {
                "balance": {
                    "type": "number"
                },
                "created_at": {
                    "type": "string"
                },
                "email": {
                    "type": "string"
                },
                "id": {
                    "type": "integer"
                },
                "name": {
                    "type": "string"
                },
                "updated_at": {
                    "type": "string"
                }
            }
        }
    }
}