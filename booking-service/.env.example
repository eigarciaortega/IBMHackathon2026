PORT=4003
PGHOST=localhost
PGPORT=5432
PGUSER=officespace
PGPASSWORD=officespace
PGDATABASE=officespace
JWT_SECRET=ibm-officespace-shared-secret-change-me
CATALOG_SERVICE_URL=http://localhost:4002

# Recordatorios automáticos
BOOKING_TIMEZONE=America/Mexico_City
BOOKING_TIMEZONE_OFFSET=-06:00
REMINDER_LEAD_MINUTES=60
REMINDER_POLL_INTERVAL_MS=60000

# Correo electrónico SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=usuario@example.com
SMTP_PASS=change-me
SMTP_FROM="OfficeSpace <no-reply@example.com>"
SMTP_SECURE=false

# WhatsApp con Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# =====================================================================
# Google Calendar (calendario embebido + auto-sincronización de reservas)
# Guía paso a paso: ../GOOGLE_CALENDAR_SETUP.md
# Si se dejan vacías, la app funciona pero el calendario sale "no configurado".
# =====================================================================
# ID del calendario compartido (lo das de alta en Google Calendar).
GOOGLE_CALENDAR_ID=
# Clave de la cuenta de servicio. Usa UNA de las dos opciones:
#   (A) JSON completo o su versión base64 (recomendado para Docker):
GOOGLE_SERVICE_ACCOUNT_KEY=
#   (B) Ruta a un archivo .json (recomendado para desarrollo local):
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=
# Opcional: URL de embed personalizada (si no, se deriva del GOOGLE_CALENDAR_ID).
GOOGLE_CALENDAR_EMBED_URL=
# Opcional: zona horaria del calendario (por defecto usa BOOKING_TIMEZONE).
GOOGLE_CALENDAR_TIMEZONE=America/Mexico_City
# Opcional: colores de evento de Google (1..11) por rol de quien reserva.
GOOGLE_EVENT_COLOR_ADMIN=11
GOOGLE_EVENT_COLOR_COLLABORATOR=9
