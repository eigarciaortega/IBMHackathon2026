# URLs base de los microservicios backend (inyectadas por Vite con prefijo VITE_).
# En docker-compose se definen apuntando a los puertos publicados.
# Para desarrollo local, si se omiten, el cliente usa estos mismos valores por defecto.
VITE_AUTH_URL=http://localhost:3001
VITE_CATALOG_URL=http://localhost:3002
VITE_BOOKING_URL=http://localhost:3003
